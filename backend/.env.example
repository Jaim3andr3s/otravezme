DATABASE_URL=postgresql://usuario:password@host/dbname?sslmode=require
JWT_SECRET=
ADMIN_SEED_PASSWORD=
GOOGLE_CLIENT_ID=
CORS_ORIGINS=http://localhost:5173,https://bibliosuenos.netlify.app,capacitor://localhost,https://localhost
PORT=4000

# Cloudinary (plan gratuito): crea una cuenta en https://cloudinary.com/users/register/free
# y copia estos 3 valores desde el Dashboard. Sin esto, subir fotos/PDF/Word no funciona.
# IMPORTANTE: en el Dashboard de Cloudinary, ve a Settings -> Security y activa
# "Allow delivery of PDF and ZIP files" (viene desactivado por defecto en cuentas
# nuevas por seguridad), o los PDF/Word subidos van a dar error 401 al abrirlos.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
