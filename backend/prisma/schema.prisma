generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookStatus {
  DISPONIBLE
  PRESTADO
}

enum EventType {
  CLUB_LECTURA
  TALLER
  CUENTACUENTOS
  CONFERENCIA
  GENERAL
  CONCURSO
  FECHA_IMPORTANTE
}

enum BookGenre {
  NARRATIVO
  LIRICO
  DRAMATICO
  INFORMATIVO
  OPINION
}

enum Publication {
  PERIODICO
  REVISTA
}

enum AchievementCategory {
  LECTURA
  JUEGO
}

enum GameType {
  TRIVIA
  MEMORY
  HANGMAN
  PUZZLE
  WORDSEARCH
  CROSSWORD
}

enum AuthProvider {
  GOOGLE
  GUEST
  EMAIL
}

model Book {
  id            Int        @id @default(autoincrement())
  title         String
  author        String
  category      String
  genre         BookGenre  @default(NARRATIVO)
  cover         String
  description   String
  status        BookStatus @default(DISPONIBLE)
  ageRange      String
  isStaffPick   Boolean    @default(false)
  isBookOfMonth Boolean    @default(false)
  readOnlineUrl String?
  rating        Float      @default(0)
  reviews       Int        @default(0)
  dateAdded     DateTime   @default(now())

  favorites   Favorite[]
  readBy      ReadBook[]
  planEntries ReadingPlanBook[]
}

model Event {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  type        EventType @default(GENERAL)
  date        DateTime
  location    String?
  imageUrl    String?
  createdAt   DateTime  @default(now())
}

model ReadingPlan {
  id            Int      @id @default(autoincrement())
  title         String
  description   String
  level         String
  durationWeeks Int
  documentUrl   String?
  createdAt     DateTime @default(now())

  books ReadingPlanBook[]
}

model ReadingPlanBook {
  id         Int         @id @default(autoincrement())
  plan       ReadingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId     Int
  book       Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)
  bookId     Int
  weekNumber Int
  note       String?

  @@unique([planId, bookId])
}

model Profile {
  id           Int          @id @default(autoincrement())
  name         String
  email        String?      @unique
  bio          String?
  avatar       String?
  joinedAt     DateTime     @default(now())
  authProvider AuthProvider @default(GUEST)
  googleId     String?      @unique
  guestToken   String?      @unique
  passwordHash String?

  favorites    Favorite[]
  read         ReadBook[]
  achievements ProfileAchievement[]
  gameScores   GameScore[]
}

model GalleryImage {
  id        Int      @id @default(autoincrement())
  url       String
  caption   String?
  createdAt DateTime @default(now())
}

model PublicationArticle {
  id          Int         @id @default(autoincrement())
  publication Publication
  section     String
  edition     String
  title       String
  author      String
  content     String
  coverImage  String?
  publishedAt DateTime    @default(now())
  createdAt   DateTime    @default(now())
}

model Favorite {
  id        Int      @id @default(autoincrement())
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId Int
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  bookId    Int
  createdAt DateTime @default(now())

  @@unique([profileId, bookId])
}

model ReadBook {
  id        Int      @id @default(autoincrement())
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId Int
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  bookId    Int
  readAt    DateTime @default(now())

  @@unique([profileId, bookId])
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Achievement {
  id          Int                 @id @default(autoincrement())
  code        String              @unique
  title       String
  description String
  icon        String
  category    AchievementCategory
  createdAt   DateTime            @default(now())

  profiles ProfileAchievement[]
}

model ProfileAchievement {
  id            Int         @id @default(autoincrement())
  profile       Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId     Int
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  achievementId Int
  earnedAt      DateTime    @default(now())

  @@unique([profileId, achievementId])
}

model GameScore {
  id        Int      @id @default(autoincrement())
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId Int
  game      GameType
  score     Int
  won       Boolean  @default(true)
  metadata  Json?
  playedAt  DateTime @default(now())
}
